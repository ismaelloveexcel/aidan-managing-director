# ---------------------------------------------------------------------------
# AI-DAN Managing Director – environment configuration template
# Copy this file to .env and fill in the values for your environment.
# NEVER commit the populated .env file to version control.
# ---------------------------------------------------------------------------

# --- Application ---
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=info

# --- OpenAI (REQUIRED for AI reasoning + output) ---
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o

# --- Perplexity (REQUIRED for market research) ---
PERPLEXITY_API_KEY=your-perplexity-api-key-here
PERPLEXITY_MODEL=sonar

# --- LLM Provider (legacy – prefer OPENAI_API_KEY above) ---
LLM_API_KEY=
LLM_MODEL=gpt-4o
LLM_BASE_URL=

# --- GitHub Integration ---
GITHUB_TOKEN=your-github-token-here
GITHUB_API_BASE_URL=https://api.github.com
GITHUB_FACTORY_OWNER=ai-dan
GITHUB_FACTORY_TEMPLATE_REPO=saas-template

# --- Factory / Build Pipeline ---
FACTORY_OWNER=ai-dan
FACTORY_REPO=ai-dan-factory
FACTORY_WORKFLOW_ID=factory-build.yml
# Base URL of the AI-DAN API used by scripts/workflows for factory endpoints
# (e.g. /factory/runs). Point this at THIS service, not a downstream factory.
FACTORY_BASE_URL=http://localhost:8000

# --- Vercel Deployment ---
VERCEL_TOKEN=your-vercel-token-here
VERCEL_TEAM_ID=

# --- Service Registry ---
REGISTRY_URL=https://registry.example.com
REGISTRY_API_KEY=your-registry-api-key-here

# --- Portfolio Database ---
PORTFOLIO_DB_PATH=data/portfolio.sqlite3

# --- Memory / Learning ---
MEMORY_MAX_EVENTS=2000
